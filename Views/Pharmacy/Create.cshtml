@model MedicineFormViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Medicine" : "Add Medicine";
    ViewData["PageTitle"] = "Pharmacy & Inventory";
}
<div class="mb-20"><a asp-action="Index" class="back-link">← Back to Pharmacy</a></div>
<div class="form-page-card">
    <div class="form-page-header">
        <h2 class="display-title">@(isEdit ? "Edit Medicine" : "Add New Medicine")</h2>
    </div>
    <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : null)" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="validation-summary"></div>
        <div class="form-grid">
            <div class="form-group full"><label asp-for="Name"></label><input asp-for="Name" class="form-control" placeholder="Medicine name & strength" /><span asp-validation-for="Name" class="field-error"></span></div>
            <div class="form-group"><label asp-for="Category"></label><select asp-for="Category" class="form-control"><option>Antibiotic</option><option>Anti-diabetic</option><option>Statin</option><option>Antacid</option><option>Analgesic</option><option>Anti-hypertensive</option><option>Antihistamine</option><option>Vitamin</option><option>Other</option></select></div>
            <div class="form-group"><label asp-for="Form">Form</label><select asp-for="Form" asp-items="Html.GetEnumSelectList<MedicineForm>()" class="form-control"></select></div>
            <div class="form-group"><label asp-for="Manufacturer"></label><input asp-for="Manufacturer" class="form-control" placeholder="Manufacturer name" /></div>
            <div class="form-group"><label asp-for="BatchNumber">Batch Number</label><input asp-for="BatchNumber" class="form-control" placeholder="Batch / lot number" /></div>
            <div class="form-group"><label asp-for="StockQuantity">Stock Quantity</label><input asp-for="StockQuantity" type="number" class="form-control" min="0" /></div>
            <div class="form-group"><label asp-for="MinimumStock">Min Stock Level</label><input asp-for="MinimumStock" type="number" class="form-control" min="0" /></div>
            <div class="form-group"><label asp-for="MaximumStock">Max Stock Level</label><input asp-for="MaximumStock" type="number" class="form-control" min="0" /></div>
            <div class="form-group"><label asp-for="UnitPrice">Unit Price (₹)</label><input asp-for="UnitPrice" type="number" step="0.01" class="form-control" min="0" /></div>
            <div class="form-group"><label asp-for="ExpiryDate">Expiry Date</label><input asp-for="ExpiryDate" type="date" class="form-control" /></div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn-primary">@(isEdit ? "Save Changes" : "Add Medicine")</button>
            <a asp-action="Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
