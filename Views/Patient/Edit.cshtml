@* Views/Patient/Edit.cshtml *@
@model PatientFormViewModel
@{
    ViewData["Title"] = "Edit Patient";
    ViewData["PageTitle"] = "Patients";
}
<div class="mb-20"><a asp-action="Index" class="back-link">← Back to Patients</a></div>
<div class="form-page-card">
    <div class="form-page-header">
        <h2 class="display-title">Edit Patient Record</h2>
        <p class="text-muted">Update the patient's details</p>
    </div>
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="validation-summary"></div>
        <div class="form-section">
            <h3 class="form-section-title">Personal Information</h3>
            <div class="form-grid">
                <div class="form-group"><label asp-for="FirstName"></label><input asp-for="FirstName" class="form-control" /><span asp-validation-for="FirstName" class="field-error"></span></div>
                <div class="form-group"><label asp-for="LastName"></label><input asp-for="LastName" class="form-control" /><span asp-validation-for="LastName" class="field-error"></span></div>
                <div class="form-group"><label asp-for="DateOfBirth"></label><input asp-for="DateOfBirth" type="date" class="form-control" /></div>
                <div class="form-group"><label asp-for="Gender"></label><select asp-for="Gender" class="form-control"><option>Male</option><option>Female</option><option>Other</option></select></div>
                <div class="form-group"><label asp-for="BloodGroup"></label><select asp-for="BloodGroup" class="form-control">@foreach(var bg in new[]{"A+","A-","B+","B-","O+","O-","AB+","AB-"}){<option value="@bg">@bg</option>}</select></div>
                <div class="form-group"><label asp-for="Status"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<PatientStatus>()" class="form-control"></select></div>
            </div>
        </div>
        <div class="form-section">
            <h3 class="form-section-title">Contact Information</h3>
            <div class="form-grid">
                <div class="form-group"><label asp-for="Phone"></label><input asp-for="Phone" class="form-control" /></div>
                <div class="form-group"><label asp-for="Email"></label><input asp-for="Email" class="form-control" /></div>
                <div class="form-group full"><label asp-for="Address"></label><input asp-for="Address" class="form-control" /></div>
            </div>
        </div>
        <div class="form-section">
            <h3 class="form-section-title">Medical Information</h3>
            <div class="form-grid">
                <div class="form-group full"><label asp-for="MedicalHistory"></label><textarea asp-for="MedicalHistory" class="form-control" rows="3"></textarea></div>
                <div class="form-group full"><label asp-for="Allergies"></label><textarea asp-for="Allergies" class="form-control" rows="2"></textarea></div>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
