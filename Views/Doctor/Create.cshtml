@model DoctorFormViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Doctor" : "Add Doctor";
    ViewData["PageTitle"] = "Doctors & Staff";
}

<div class="mb-20"><a asp-action="Index" class="back-link">← Back to Staff</a></div>

<div class="form-page-card">
    <div class="form-page-header">
        <h2 class="display-title">@(isEdit ? "Edit Doctor Record" : "Add New Doctor")</h2>
        <p class="text-muted">@(isEdit ? "Update staff information" : "Register a new staff member")</p>
    </div>

    <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : null)" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="validation-summary"></div>

        <div class="form-section">
            <h3 class="form-section-title">Personal Details</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="FirstName"></label>
                    <input asp-for="FirstName" class="form-control" placeholder="First name" />
                    <span asp-validation-for="FirstName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName"></label>
                    <input asp-for="LastName" class="form-control" placeholder="Last name" />
                    <span asp-validation-for="LastName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" class="form-control" placeholder="+91 XXXXX XXXXX" />
                    <span asp-validation-for="Phone" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="doctor@hospital.in" />
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Professional Details</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Specialization"></label>
                    <input asp-for="Specialization" class="form-control" placeholder="e.g., Cardiologist" />
                    <span asp-validation-for="Specialization" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Department"></label>
                    <select asp-for="Department" class="form-control">
                        @foreach (var d in new[]{"Cardiology","Neurology","Orthopedics","Dermatology","Gynecology","Pediatrics","General Medicine","Radiology","Emergency"})
                        { <option value="@d">@d</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="Qualification"></label>
                    <input asp-for="Qualification" class="form-control" placeholder="e.g., MD, DM Cardiology" />
                </div>
                <div class="form-group">
                    <label asp-for="LicenseNumber"></label>
                    <input asp-for="LicenseNumber" class="form-control" placeholder="MCI license number" />
                </div>
                <div class="form-group">
                    <label asp-for="ExperienceYears"></label>
                    <input asp-for="ExperienceYears" type="number" class="form-control" min="0" max="60" />
                </div>
                <div class="form-group">
                    <label asp-for="Status"></label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<DoctorStatus>()" class="form-control"></select>
                </div>
                <div class="form-group">
                    <label asp-for="AvatarColor">Avatar Color</label>
                    <input asp-for="AvatarColor" type="color" class="form-control" style="height:42px;padding:4px" />
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">@(isEdit ? "Save Changes" : "Add Doctor")</button>
            <a asp-action="Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
