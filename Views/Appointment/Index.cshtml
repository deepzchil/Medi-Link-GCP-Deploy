@* ===== Appointment/Index.cshtml ===== *@
@model AppointmentListViewModel
@{
    ViewData["Title"] = "Appointments";
    ViewData["PageTitle"] = "Appointments";
}
<div class="flex-between mb-20">
    <div><h2 class="display-title">Appointments</h2><p class="text-muted">Manage all patient appointments</p></div>
    <a asp-action="Create" class="btn-primary">+ New Appointment</a>
</div>
<div class="tab-bar mb-20">
    <a asp-action="Index" class="tab @(Model.DateFilter == null ? "active" : "")">All (@Model.TotalCount)</a>
    <a asp-action="Index" asp-route-date="today" class="tab @(Model.DateFilter == "today" ? "active" : "")">Today</a>
    <a asp-action="Index" asp-route-date="upcoming" class="tab @(Model.DateFilter == "upcoming" ? "active" : "")">Upcoming</a>
    <a asp-action="Index" asp-route-date="past" class="tab @(Model.DateFilter == "past" ? "active" : "")">Past</a>
</div>
<div class="card">
    <div class="card-body pb-0">
        <form asp-action="Index" method="get" class="filter-bar">
            <div class="search-bar flex-1"><span>🔍</span><input type="text" name="search" placeholder="Search patient or doctor…" value="@Model.SearchTerm" /></div>
            <select name="status" class="form-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (AppointmentStatus s in Enum.GetValues(typeof(AppointmentStatus)))
                { <option value="@s" selected="@(Model.StatusFilter == s.ToString())">@s</option> }
            </select>
            <button type="submit" class="btn-secondary">Filter</button>
        </form>
    </div>
    <div class="table-wrap">
        <table>
            <thead><tr><th>Patient</th><th>Doctor</th><th>Department</th><th>Date & Time</th><th>Type</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var a in Model.Appointments)
                {
                    <tr>
                        <td><div class="td-name">@a.Patient?.FullName</div><div class="td-sub">@a.Patient?.PatientCode</div></td>
                        <td>@a.Doctor?.FullName</td>
                        <td>@a.Department</td>
                        <td>@a.AppointmentDate.ToString("dd MMM") · @(DateTime.Today + a.AppointmentTime).ToString("hh:mm tt")</td>
                        <td><span class="badge badge-info">@a.Type</span></td>
                        <td><span class="badge badge-@(a.Status==AppointmentStatus.Confirmed?"success":a.Status==AppointmentStatus.Cancelled?"danger":a.Status==AppointmentStatus.Completed?"gray":"warn")">@a.Status</span></td>
                        <td>
                            <div class="action-btns">
                                <a asp-action="Detail" asp-route-id="@a.Id" class="btn-sm">View</a>
                                <a asp-action="Edit" asp-route-id="@a.Id" class="btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@a.Id" method="post" style="display:inline" onsubmit="return confirm('Delete?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-sm btn-danger-sm">Del</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Appointments.Any()) { <tr><td colspan="7" class="text-center text-muted py-20">No appointments found.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
