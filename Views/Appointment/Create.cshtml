@* Views/Appointment/Create.cshtml *@
@model AppointmentFormViewModel
@{
    ViewData["Title"] = "Book Appointment";
    ViewData["PageTitle"] = "Appointments";
}
<div class="mb-20"><a asp-action="Index" class="back-link">← Back to Appointments</a></div>
<div class="form-page-card">
    <div class="form-page-header"><h2 class="display-title">Book New Appointment</h2><p class="text-muted">Schedule a patient appointment</p></div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="validation-summary"></div>
        <div class="form-section">
            <div class="form-grid">
                <div class="form-group full">
                    <label asp-for="PatientId">Patient</label>
                    <select asp-for="PatientId" class="form-control">
                        <option value="">— Select Patient —</option>
                        @foreach (var p in Model.Patients) { <option value="@p.Id">@p.FullName (@p.PatientCode)</option> }
                    </select>
                    <span asp-validation-for="PatientId" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DoctorId">Doctor</label>
                    <select asp-for="DoctorId" class="form-control">
                        <option value="">— Select Doctor —</option>
                        @foreach (var d in Model.Doctors) { <option value="@d.Id">@d.FullName — @d.Department</option> }
                    </select>
                    <span asp-validation-for="DoctorId" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Department"></label>
                    <select asp-for="Department" class="form-control">
                        @foreach (var dept in new[]{"Cardiology","Neurology","Orthopedics","Dermatology","Gynecology","Pediatrics","General Medicine","Radiology"})
                        { <option value="@dept">@dept</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="AppointmentDate">Date</label>
                    <input asp-for="AppointmentDate" type="date" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="AppointmentTime">Time</label>
                    <input asp-for="AppointmentTime" type="time" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Type">Appointment Type</label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<AppointmentType>()" class="form-control"></select>
                </div>
                <div class="form-group">
                    <label asp-for="Status"></label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<AppointmentStatus>()" class="form-control"></select>
                </div>
                <div class="form-group full">
                    <label asp-for="Notes">Notes / Reason for Visit</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Describe symptoms or reason for visit…"></textarea>
                </div>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn-primary">Book Appointment</button>
            <a asp-action="Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
